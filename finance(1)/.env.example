# <<< INTEGRATION: frontend environment variables >>>

# Gemini AI key (AI Studio injects this automatically)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Backend API base URL.
# Dev:  leave empty — Vite proxy forwards /api to http://localhost:8000
# Prod: set to your backend service URL, e.g. https://api.myapp.com
VITE_API_URL=""
