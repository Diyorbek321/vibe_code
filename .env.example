# ─── Database ───────────────────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financebot
DB_URL_SYNC=postgresql://postgres:postgres@localhost:5432/financebot

# ─── Security ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ─── Telegram ───────────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
WEBHOOK_URL=https://your-domain.com   # public base URL (production only)
WEBHOOK_SECRET=your-webhook-secret    # optional

# ─── AI provider (Groq recommended — free tier, fast) ───────────────────────────
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# ─── Voice-to-text ──────────────────────────────────────────────────────────────
WHISPER_MODEL=whisper-large-v3        # Groq Whisper model
WHISPER_LANGUAGE=uz                   # Uzbek by default, remove for auto-detect

# ─── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
TZ=Asia/Tashkent
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ─── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URLS=http://localhost:3000,http://localhost:5173

# ─── Redis (optional — FSM state persists across bot restarts) ──────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Internal bot → dashboard sync ──────────────────────────────────────────────
# Used in dev (polling mode): bot notifies FastAPI via HTTP so SSE works cross-process
INTERNAL_API_URL=http://localhost:8000
# INTERNAL_SECRET=set-a-secret-in-production
